{
    "name": "vehicle-service-saas",
    "version": "1.0.0",
    "description": "Multi-tenant Vehicle Service Management SaaS",
    "main": "dist/server.js",
    "scripts": {
        "dev": "ts-node-dev --respawn --transpile-only --exit-child src/server.ts",
        "build": "tsc",
        "start": "node dist/server.js",
        "start:prod": "cross-env NODE_ENV=production node dist/server.js",
        "pm2:start": "pm2 start ecosystem.config.js",
        "pm2:stop": "pm2 stop ecosystem.config.js",
        "pm2:restart": "pm2 restart ecosystem.config.js",
        "pm2:logs": "pm2 logs",
        "test": "jest",
        "test:watch": "jest --watch",
        "test:coverage": "jest --coverage",
        "test:integration": "jest --config jest.integration.config.js",
        "lint": "eslint src/**/*.ts",
        "lint:fix": "eslint src/**/*.ts --fix",
        "format": "prettier --write \"src/**/*.ts\"",
        "typecheck": "tsc --noEmit",
        "clean": "rm -rf dist",
        "seed:dev": "cross-env NODE_ENV=development SEED_SAMPLE_DATA=true ts-node src/seeds/run.ts",
        "seed:prod": "cross-env NODE_ENV=production ts-node src/seeds/run.ts",
        "migrate": "ts-node src/scripts/migrate.ts",
        "backup": "ts-node src/scripts/backup.ts",
        "monitor": "ts-node src/scripts/monitor.ts"
    },
    "keywords": [
        "saas",
        "vehicle",
        "service",
        "maintenance"
    ],
    "author": "",
    "license": "ISC",
    "dependencies": {
        "bcryptjs": "^2.4.3",
        "compression": "^1.7.4",
        "cookie-parser": "^1.4.7",
        "cors": "^2.8.5",
        "crypto": "^1.0.1",
        "dotenv": "^16.3.1",
        "express": "^4.18.2",
        "express-mongo-sanitize": "^2.2.0",
        "express-rate-limit": "^7.1.5",
        "handlebars": "^4.7.8",
        "helmet": "^7.1.0",
        "hpp": "^0.2.3",
        "ioredis": "^5.3.2",
        "jsonwebtoken": "^9.0.2",
        "mongoose": "^8.0.3",
        "morgan": "^1.10.0",
        "multer": "^1.4.5-lts.1",
        "nodemailer": "^6.9.7",
        "pino": "^8.17.2",
        "pino-pretty": "^10.3.1",
        "twilio": "^4.20.0",
        "uuid": "^13.0.0",
        "winston": "^3.11.0",
        "xss": "^1.0.15",
        "zod": "^3.22.4"
    },
    "devDependencies": {
        "@types/bcryptjs": "^2.4.6",
        "@types/compression": "^1.7.5",
        "@types/cors": "^2.8.17",
        "@types/express": "^4.17.21",
        "@types/jest": "^29.5.11",
        "@types/jsonwebtoken": "^9.0.5",
        "@types/morgan": "^1.9.9",
        "@types/multer": "^1.4.11",
        "@types/node": "^20.10.6",
        "@types/nodemailer": "^6.4.14",
        "@typescript-eslint/eslint-plugin": "^6.16.0",
        "@typescript-eslint/parser": "^6.16.0",
        "cross-env": "^10.1.0",
        "eslint": "^8.56.0",
        "jest": "^29.7.0",
        "prettier": "^3.1.1",
        "ts-jest": "^29.1.1",
        "ts-node": "^10.9.2",
        "ts-node-dev": "^2.0.0",
        "typescript": "^5.3.3"
    },
    "engines": {
        "node": ">=18.0.0"
    }
}
